# ── Python FastAPI environment variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Run uvicorn from the project root so load_dotenv() picks this up.

# Alpha Vantage API key (recommended) — primary source for stock data
# Free tier: 25 requests/day  |  Get a key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Anthropic API key (optional) — enables Claude Haiku AI explanations
# If not set, the bot falls back to Ollama then a rule-based explanation
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
