# Telegram bot token (required) — get from @BotFather
TOKEN=your_telegram_bot_token_here

# Anthropic API key (optional) — enables Claude Haiku explanations
# If not set, the bot falls back to Ollama then a rule-based explanation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Python FastAPI base URL (optional) — default: http://localhost:8000
# Change this if your FastAPI runs on a different host/port
PYTHON_API_URL=http://localhost:8000
